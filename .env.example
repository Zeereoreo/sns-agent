# 이 파일을 복사해 .env 로 만들고 값을 채우세요.  (실제 .env 는 git에 올라가지 않습니다)
# 복사:  Copy-Item .env.example .env

# ===== Claude (Anthropic) API =====
# 발급: https://console.anthropic.com/  ->  API Keys
ANTHROPIC_API_KEY=sk-ant-여기에_키_입력
# 초안 생성 모델 (품질: claude-opus-4-8  /  비용절감: claude-sonnet-5)
CLAUDE_MODEL=claude-opus-4-8

# ===== 네이버 블로그 =====
# 자동 로그인은 탐지 위험이 커서 하지 않습니다.
# 최초 1회 사람이 직접 로그인한 세션(storage_state)을 재사용합니다.
NAVER_BLOG_ID=your_blog_id

# ===== 게시 안전장치 (계정 정지/저품질 회피) =====
MAX_POSTS_PER_DAY=1
PUBLISH_WINDOW_START=08:00
PUBLISH_WINDOW_END=10:00
